/* ==========================================================================
   Página de Produtos — barra lateral de categorias + vitrine
   ========================================================================== */

.produtos {
  padding-block: 2rem 3.5rem;
}

.produtos__layout {
  display: grid;
  gap: 2rem;
  grid-template-columns: 220px 1fr;
  align-items: start;
}

/* Barra lateral */
.categoria-sidebar {
  position: sticky;
  top: calc(68px + 1.25rem);
}
.categoria-sidebar h2 {
  font-family: var(--font-display);
  text-transform: uppercase;
  font-size: 0.85rem;
  letter-spacing: 0.04em;
  color: var(--muted);
  margin: 0 0 0.75rem;
}
.categoria-list {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}
.categoria-list button {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.5rem;
  width: 100%;
  text-align: left;
  padding: 0.55rem 0.7rem;
  border-radius: var(--radius-sm);
  font-size: 0.88rem;
  color: var(--muted);
  border: 1px solid transparent;
  transition: background-color 0.15s ease, color 0.15s ease, border-color 0.15s ease;
}
.categoria-list button:hover {
  color: var(--fg);
  background: var(--surface);
}
.categoria-list button[aria-pressed="true"] {
  color: var(--fg);
  background: var(--surface);
  border-color: var(--border);
}
.categoria-list button[aria-pressed="true"] .categoria-dot {
  background: var(--gold);
}
.categoria-dot {
  width: 7px;
  height: 7px;
  border-radius: 999px;
  background: var(--muted);
  flex-shrink: 0;
}
.categoria-count {
  font-size: 0.72rem;
  color: var(--muted);
}

/* Vitrine */
.produtos__heading {
  margin-bottom: 1.5rem;
}
.produtos__heading h1 {
  font-family: var(--font-display);
  text-transform: uppercase;
  font-size: clamp(1.6rem, 3.5vw, 2.2rem);
  letter-spacing: 0.01em;
  margin: 0;
}
.produtos__heading p {
  color: var(--muted);
  margin: 0.4rem 0 0;
  max-width: 60ch;
}

.produto-grupo {
  margin-bottom: 2.5rem;
}
.produto-grupo__head {
  display: flex;
  align-items: baseline;
  gap: 0.6rem;
  margin-bottom: 1rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid var(--border);
}
.produto-grupo__head h3 {
  font-family: var(--font-display);
  text-transform: uppercase;
  font-size: 1.1rem;
  margin: 0;
}
.produto-grupo__head span {
  font-size: 0.75rem;
  color: var(--muted);
}

.produto-grid {
  display: grid;
  gap: 1.1rem;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
}

.produto-card {
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  background: linear-gradient(160deg, var(--surface), var(--surface-2));
  padding: 1.1rem;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}
.produto-card__tag {
  font-size: 0.62rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--gold);
}
.produto-card h4 {
  font-size: 1rem;
  margin: 0;
  line-height: 1.3;
}
.produto-card p {
  font-size: 0.85rem;
  color: var(--muted);
  margin: 0;
  flex-grow: 1;
}
.produto-card__links {
  display: flex;
  gap: 0.5rem;
  margin-top: 0.3rem;
}

/* Botões de afiliado — cor associada à marca, sem reproduzir o logo oficial */
.afiliado-btn {
  flex: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.4rem;
  padding: 0.55rem 0.5rem;
  border-radius: var(--radius-sm);
  font-size: 0.78rem;
  font-weight: 600;
  transition: filter 0.15s ease, transform 0.15s ease;
}
.afiliado-btn:hover { filter: brightness(1.08); transform: translateY(-1px); }
.afiliado-btn--amazon { background: #ff9900; color: #0c0c0e; }
.afiliado-btn--ml { background: #fee600; color: #0c0c0e; }

.produtos__disclaimer {
  margin-top: 2rem;
  font-size: 0.72rem;
  color: var(--muted);
  border-top: 1px solid var(--border);
  padding-top: 1rem;
}

/* Mobile: barra lateral vira lista horizontal de chips no topo */
@media (max-width: 860px) {
  .produtos__layout {
    grid-template-columns: 1fr;
  }
  .categoria-sidebar {
    position: static;
  }
  .categoria-list {
    flex-direction: row;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .categoria-list button {
    width: auto;
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.4rem 0.8rem;
  }
  .categoria-count { display: none; }
}
